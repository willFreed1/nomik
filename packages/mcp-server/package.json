{
    "name": "@genome/mcp-server",
    "version": "0.1.0",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "node -e \"const fs = require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist', {recursive: true})\"",
        "start": "node dist/index.js"
    },
    "dependencies": {
        "@genome/core": "workspace:*",
        "@genome/graph": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "tsup": "^8.0.1",
        "typescript": "^5.3.3"
    }
}